# =============================================================================
# DPN — Split-architecture environment schema
# =============================================================================
# DPN runs across TWO domains:
#   1. Vercel     — the interactive frontend + API  (dpn-shop-live.vercel.app)
#   2. WordPress  — the content / admin hub         (e.g. delpilarnails.dk)
#
# Copy this file to `.env.local` and fill values. NEVER commit `.env.local`.
# In Vercel: Settings → Environment Variables → Production. Same key names.
# =============================================================================


# -----------------------------------------------------------------------------
# AI models (Claude is primary; OpenAI kept for optional streaming endpoints)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=                     # optional — enables gpt-4o-mini streaming routes


# -----------------------------------------------------------------------------
# Application Domain — Vercel
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VERCEL_URL=https://dpn-shop-live.vercel.app
PUBLIC_SITE_URL=https://dpn-shop-live.vercel.app

# WordPress origin allowed to CORS-fetch our API (must match Origin header exactly)
ALLOWED_ORIGIN_WORDPRESS=https://delpilarnails.dk


# -----------------------------------------------------------------------------
# Content / Admin Domain — WordPress
# -----------------------------------------------------------------------------
WORDPRESS_URL=https://delpilarnails.dk
WORDPRESS_USER=                     # WP admin username with REST-API access
WORDPRESS_APP_PASSWORD=             # WP Application Password (Users → Profile → Application Passwords)

# Long random string used to authenticate cross-domain admin calls + Vercel Cron.
# Generate: `openssl rand -hex 32`
ADMIN_SECRET_KEY=
# Backward-compatible alias used by selected admin/harness handlers
DPN_ADMIN_KEY=
# Optional secondary admin token for legacy admin endpoints
DPN_ADMIN_TOKEN=


# -----------------------------------------------------------------------------
# Supabase — DPN LIVE learning store (sycmpguhdudyejmxxaic)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://sycmpguhdudyejmxxaic.supabase.co
SUPABASE_SERVICE_KEY=
# Alias used in some handlers
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# Stripe (live keys)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Image generation (fal.ai)
# -----------------------------------------------------------------------------
FAL_KEY=


# -----------------------------------------------------------------------------
# Publishing — Direct platform tokens (preferred) OR Zapier webhooks (fallback)
# -----------------------------------------------------------------------------
# Instagram
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=
ZAPIER_INSTAGRAM_HOOK=

# TikTok
TIKTOK_ACCESS_TOKEN=
ZAPIER_TIKTOK_HOOK=

# Facebook page direct token
FACEBOOK_PAGE_ACCESS_TOKEN=

# X/Twitter bearer token
TWITTER_BEARER_TOKEN=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_URN=          # e.g. urn:li:organization:12345
ZAPIER_LINKEDIN_HOOK=

# Newsletter — Resend direct OR Zapier
RESEND_API_KEY=
RESEND_FROM_EMAIL=DPN <hello@delpilarnails.dk>
RESEND_AUDIENCE_ID=
ZAPIER_NEWSLETTER_HOOK=

# Order-ack email
ZAPIER_ORDER_EMAIL_HOOK=


# -----------------------------------------------------------------------------
# Customer support — Postmark Inbound (Karla)
# -----------------------------------------------------------------------------
# REQUIRED before pointing Postmark Inbound at /api/agents/karla — endpoint is
# fail-closed until this is set.
POSTMARK_INBOUND_SECRET=

# Optional Postmark server token (outbound)
POSTMARK_SERVER_TOKEN=
# Alias keys used by selected mail handlers
POSTMARK_TOKEN=
POSTMARK_API_KEY=
POSTMARK_FROM=
POSTMARK_REPLY_TO=

# Self-hosted service URLs
INKLING_URL=
VISION_SERVICE_URL=

# External business integrations
TINKER_API_KEY=
CVR_API_KEY=

# B2B security salt
B2B_SALT=

# B2B logistics defaults
DPN_RETURN_ADDRESS=


# -----------------------------------------------------------------------------
# Agent auth
# -----------------------------------------------------------------------------
# When set, /api/agents/outreach requires `Authorization: Bearer <this>`
OUTREACH_API_KEY=

# When set, /api/agents/anna auto-sends emails via Resend; when unset AND
# PENDING_HUMAN_STRICT=1, anna queues everything for human approval first.
PENDING_HUMAN_STRICT=1


# -----------------------------------------------------------------------------
# Feature flags and runtime tuning
# -----------------------------------------------------------------------------
FEATURE_ANALYTICS_FORWARD_ENABLED=1
FEATURE_QUICK_AR_ENABLED=1
FEATURE_STUDIO_SCAN_ENABLED=1
FEEDBACK_LOOKBACK_HOURS=24
FEEDBACK_MAX_LESSONS_PER_RUN=10
FEEDBACK_PROMOTE_THRESHOLD=0.75
FREJA_AUTO_PUSH=0


# -----------------------------------------------------------------------------
# Social/channel platform keys (optional by channel)
# -----------------------------------------------------------------------------
META_ACCESS_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_CATALOG_ID=
META_COMMERCE_TOKEN=
FACEBOOK_PAGE_ID=
PAGE_ACCESS_TOKEN=

LINKEDIN_PERSON_URN=

THREADS_ACCESS_TOKEN=

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

GBP_ACCESS_TOKEN=
GBP_LOCATION_ID=


# -----------------------------------------------------------------------------
# Analytics/observability
# -----------------------------------------------------------------------------
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
VERCEL_EDGE_CONFIG_ID=
VERCEL_TEAM_AUTH_TOKEN=
VERCEL_URL=


# -----------------------------------------------------------------------------
# Push notifications and uploads
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
UPLOAD_DIR=./uploads
PRODUCT_IMAGE_BASE_URL=


# -----------------------------------------------------------------------------
# Vision/ML optional integrations
# -----------------------------------------------------------------------------
ROBOFLOW_API_KEY=
VLLM_HOST=
