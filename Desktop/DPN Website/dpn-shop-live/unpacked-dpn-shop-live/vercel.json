{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/*.js": { "maxDuration": 30 },
    "api/agents/*.js": { "maxDuration": 60 },
    "api/admin/*.js": { "maxDuration": 30 },
    "api/publish/*.js": { "maxDuration": 30 },
    "api/harness/**/*.js": { "maxDuration": 120 },
    "api/vision/*.js": { "maxDuration": 30 },
    "api/commerce/*.js": { "maxDuration": 60 },
    "api/newsletter/*.js": { "maxDuration": 10 },
    "api/activation/*.js": { "maxDuration": 30 },
    "api/self-improve/*.js": { "maxDuration": 60 },
    "api/b2b/*.js": { "maxDuration": 30 },
    "api/social-shops/*.js": { "maxDuration": 60 },
    "api/analytics/*.js": { "maxDuration": 60 },
    "api/configurator-v2/*.js": { "maxDuration": 60 },
    "api/advisor/*.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/harness/autonomous/cron-poll",   "schedule": "* * * * *" },
    { "path": "/api/harness/autonomous/auto-execute", "schedule": "*/2 * * * *" },
    { "path": "/api/harness/autonomous/reflection",  "schedule": "*/15 * * * *" },
    { "path": "/api/harness/autonomous/self-heal",   "schedule": "*/5 * * * *" },
    { "path": "/api/harness/autonomous/calibrate",   "schedule": "0 * * * *" },
    { "path": "/api/harness/autonomous/scheduler",   "schedule": "*/15 * * * *" },
    { "path": "/api/harness/autonomous/orchestrator", "schedule": "*/3 * * * *" },
    { "path": "/api/harness/s-agents/web",           "schedule": "*/5 * * * *" },
    { "path": "/api/harness/s-agents/inventory",     "schedule": "0 * * * *" },
    { "path": "/api/harness/s-agents/feedback",      "schedule": "*/30 * * * *" },
    { "path": "/api/harness/s-agents/competitor",    "schedule": "0 */6 * * *" },
    { "path": "/api/harness/s-agents/balance",       "schedule": "*/15 * * * *" },
    { "path": "/api/agents/clara?channel=instagram", "schedule": "0 8 * * 1" },
    { "path": "/api/agents/clara?channel=tiktok",   "schedule": "0 8 * * 3" },
    { "path": "/api/agents/clara?channel=linkedin", "schedule": "0 8 * * 5" },
    { "path": "/api/agents/nikoline",               "schedule": "0 8 1 * *" },
    { "path": "/api/agents/trine",                  "schedule": "0 7 * * 1" },
    { "path": "/api/agents/drop",                   "schedule": "0 8 * * *" },
    { "path": "/api/agents/ida",                    "schedule": "30 7 * * 1" },
    { "path": "/api/agents/feedback",               "schedule": "0 2 * * *" },
    { "path": "/api/agents/anna?task=cron_in_production", "schedule": "0 */4 * * *" },
    { "path": "/api/agents/astrid",                 "schedule": "0 4 * * *" },
    { "path": "/api/admin/sync-wordpress",          "schedule": "0 5 * * *" },
    { "path": "/api/harness/tinker-max-power",      "schedule": "0 2 * * *" },
    { "path": "/api/activation/health-check",       "schedule": "*/15 * * * *" },
    { "path": "/api/self-improve/reflect",          "schedule": "0 3 * * *" },
    { "path": "/api/self-improve/prune",            "schedule": "0 4 * * 0" },
    { "path": "/api/self-improve/evolve",           "schedule": "0 5 1 * *" },
    { "path": "/api/analytics/trend-scanner",        "schedule": "0 6 * * 1" },
    { "path": "/api/analytics/competitor",           "schedule": "0 */6 * * *" },
    { "path": "/api/analytics/report",               "schedule": "0 7 * * 1" },
    { "path": "/api/social-shops/instagram-shop",    "schedule": "0 6 * * *" },
    { "path": "/api/social-shops/tiktok-shop",       "schedule": "0 6 * * *" },
    { "path": "/api/social-shops/pinterest-shop",    "schedule": "0 6 * * *" }
  ]
}
